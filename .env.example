# Database — get a free PostgreSQL connection string from neon.tech or supabase.com
DATABASE_URL="postgresql://user:password@host:5432/marathon_companion"

# Bungie API — register at https://www.bungie.net/en/Application
BUNGIE_API_KEY="your_api_key_here"

# Bungie OAuth — from your application registration
BUNGIE_CLIENT_ID="your_client_id_here"

# Only required for confidential clients (server-side OAuth with refresh tokens)
# Leave blank if using a public client
BUNGIE_CLIENT_SECRET=""

# The URL Bungie will redirect to after OAuth login
# Must match EXACTLY what you registered in the Bungie dev portal
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BUNGIE_REDIRECT_URI="http://localhost:3000/api/auth/bungie/callback"

# Random secret used to sign cookies / CSRF state tokens
# Generate one: openssl rand -hex 32
AUTH_SECRET="change_me_to_a_random_32_byte_hex_string"
