generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ASSAULT
  STEALTH
  INTEL
  MOBILITY
  SUPPORT
  LOOT
  SCAVENGER
}

enum Rarity {
  STANDARD
  ENHANCED
  DELUXE
  SUPERIOR
  PRESTIGE
}

enum WeaponType {
  ASSAULT_RIFLE
  SMG
  PRECISION_RIFLE
  SHOTGUN
  PISTOL
  MACHINE_GUN
  SNIPER_RIFLE
  RAILGUN
  MELEE
}

enum ModSlot {
  OPTIC
  BARREL
  MAGAZINE
  GRIP
  CHIP
  SHIELD
}

enum ImplantSlot {
  HEAD
  TORSO
  LEGS
  SHIELD
}

model Shell {
  id               String   @id @default(cuid())
  name             String   @unique
  description      String
  role             Role
  primeAbilityName String
  primeAbilityDesc String
  primeCooldown    Int
  tactAbilityName  String
  tactAbilityDesc  String
  tactCooldown     Int
  trait1Name       String   @default("")
  trait1Desc       String   @default("")
  trait2Name       String   @default("")
  trait2Desc       String   @default("")
  baseStats        Json     // { health, shield, speed, resilience, recovery }
  iconUrl          String   @default("")
  cores            Core[]
  builds           Build[]
  createdAt        DateTime @default(now())
}

model Weapon {
  id          String     @id @default(cuid())
  name        String     @unique
  type        WeaponType
  rarity      Rarity
  firepower   Float
  rateOfFire  Int
  range       Int
  accuracy    Float
  magazine    Int
  reloadSpeed Float
  recoil      Float
  precision   Float
  fireMode    String     @default("")
  ammoType    String     @default("")
  description String
  iconUrl     String     @default("")
  mods        WeaponMod[] @relation("WeaponToMods")
  builds      Build[]     @relation("BuildWeapons")
  createdAt   DateTime    @default(now())
}

model WeaponMod {
  id            String   @id @default(cuid())
  name          String   @unique
  slot          ModSlot
  statModifiers Json     // { range: +10, recoil: -5, etc. }
  description   String
  rarity        Rarity
  weapons       Weapon[] @relation("WeaponToMods")
  builds        Build[]  @relation("BuildWeaponMods")
  createdAt     DateTime @default(now())
}

model Core {
  id                  String   @id @default(cuid())
  name                String   @unique
  shellId             String
  shell               Shell    @relation(fields: [shellId], references: [id])
  abilityModification String
  statModifiers       Json     // { health: +20, speed: -5, etc. }
  rarity              Rarity
  builds              Build[]
  createdAt           DateTime @default(now())
}

model Implant {
  id          String      @id @default(cuid())
  name        String      @unique
  slot        ImplantSlot
  statBonuses Json        // { heatCapacity: +15, lootSpeed: +8, etc. }
  rarity      Rarity
  description String
  perk        String      @default("")
  builds      Build[]     @relation("BuildImplants")
  createdAt   DateTime    @default(now())
}

model Build {
  id           String      @id @default(cuid())
  name         String
  shellId      String
  shell        Shell       @relation(fields: [shellId], references: [id])
  coreId       String?
  core         Core?       @relation(fields: [coreId], references: [id])
  implants     Implant[]   @relation("BuildImplants")
  weapons      Weapon[]    @relation("BuildWeapons")
  weaponMods   WeaponMod[] @relation("BuildWeaponMods")
  totalStats   Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
